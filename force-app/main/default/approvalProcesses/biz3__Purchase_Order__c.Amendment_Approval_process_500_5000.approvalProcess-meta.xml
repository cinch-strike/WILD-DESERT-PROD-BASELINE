<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>PO_Requested_By__c</field>
        <field>Old_Total_Tax_10__c</field>
        <field>Amendment_Amount_Currency__c</field>
        <field>Old_Total_Tax_exc__c</field>
        <field>Recharge_Invoice_del__c</field>
        <field>biz3__Total_exc_Tax__c</field>
        <field>biz3__Total_inc_Tax__c</field>
        <field>biz3__Contact__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <description>This Approval process is created to handle PO Amendment if total PO price is between $500 - $5000</description>
        <entryCriteria>
            <criteriaItems>
                <field>biz3__Purchase_Order__c.biz3__Total_inc_Tax__c</field>
                <operation>greaterThan</operation>
                <value>500</value>
            </criteriaItems>
            <criteriaItems>
                <field>biz3__Purchase_Order__c.biz3__Total_inc_Tax__c</field>
                <operation>lessThan</operation>
                <value>5000</value>
            </criteriaItems>
            <criteriaItems>
                <field>biz3__Purchase_Order__c.Amendment_Amount_Percentage__c</field>
                <operation>greaterThan</operation>
                <value>30</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>$500-$5000-30%</label>
        <name>X500_5000_30</name>
    </approvalStep>
    <description>This Approval process is created to handle PO Amendment From $500 to $5,000 30%</description>
    <emailTemplate>Purchase/Purchase_Order_Amended_For_Approval</emailTemplate>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Status__c</field>
            <operation>equals</operation>
            <value>Amendment</value>
        </criteriaItems>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Total_inc_Tax__c</field>
            <operation>greaterThan</operation>
            <value>501</value>
        </criteriaItems>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Total_inc_Tax__c</field>
            <operation>lessThan</operation>
            <value>5000</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Update_PO_Record_Type_to_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Update_PO_Status_to_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Purchase_Order_Not_Apporved</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_PO_Status_to_Not_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>true</finalRejectionRecordLock>
    <label>Amendment Approval process $500-$5000</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>true</useApproverFieldOfRecordOwner>
        <userHierarchyField>approver__c</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>3</processOrder>
    <recallActions>
        <action>
            <name>Update_PO_Status_to_recalled</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
