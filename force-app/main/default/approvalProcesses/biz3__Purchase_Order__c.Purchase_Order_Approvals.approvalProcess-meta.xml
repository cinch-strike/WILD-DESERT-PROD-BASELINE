<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>creator</type>
    </allowedSubmitters>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>biz3__Date__c</field>
        <field>Name</field>
        <field>biz3__Description__c</field>
        <field>biz3__Account__c</field>
        <field>PO_Requested_By__c</field>
        <field>Date_Required__c</field>
        <field>biz3__Total_exc_Tax__c</field>
        <field>biz3__Total_inc_Tax__c</field>
        <field>biz3__Status__c</field>
        <field>Owner</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>biz3__Purchase_Order__c.biz3__Total_exc_Tax__c</field>
                <operation>lessOrEqual</operation>
                <value>4999</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Under 5K approvals</label>
        <name>Under_5K_approvals</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Approved_Po_s</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Update_Record_Type_to_Approved</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>carmen.roberts@wilddesert.com.au</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>biz3__Purchase_Order__c.biz3__Total_exc_Tax__c</field>
                <operation>greaterThan</operation>
                <value>4999</value>
            </criteriaItems>
            <criteriaItems>
                <field>User.purchase_order_approvals__c</field>
                <operation>equals</operation>
                <value>00590000000qPwn</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>Send to Gina to Approve</label>
        <name>Approval_Step</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>Not_Approved_Not_Started</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Purchase_Order_Not_Apporved</name>
                <type>Alert</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Approved_Po_s</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Update_Record_Type_to_Approved</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>carmen.roberts@wilddesert.com.au</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>biz3__Purchase_Order__c.biz3__Total_exc_Tax__c</field>
                <operation>greaterThan</operation>
                <value>4999</value>
            </criteriaItems>
            <criteriaItems>
                <field>User.purchase_order_approvals__c</field>
                <operation>equals</operation>
                <value>00590000000qro3</value>
            </criteriaItems>
        </entryCriteria>
        <label>Send to David for Approval</label>
        <name>Send_to_David_for_Approval</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
        <rejectionActions>
            <action>
                <name>Not_Approved_Not_Started</name>
                <type>FieldUpdate</type>
            </action>
            <action>
                <name>Purchase_Order_Not_Apporved</name>
                <type>Alert</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <description>Not In Use</description>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Status__c</field>
            <operation>equals</operation>
            <value>Not Started</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionRecordLock>true</finalRejectionRecordLock>
    <label>Not In Use Purchase Order Approvals New</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>1</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
