    <description>This is the Amended PO approval process for wild desert created 12/11/2013</description>
    <emailTemplate>Purchase/Purchase_Order_Amended_For_Approval</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Total_inc_Tax__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Status__c</field>
            <operation>equals</operation>
            <value>In Progress - Amended</value>
        </criteriaItems>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Status__c</field>
            <operation>notEqual</operation>
            <value>Approved</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Amendment_Approved</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_PO_Record_Type_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Update_Status_To_Approved_Amended</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>PO_Request_Rejected</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_Status_To_Not_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Update_PO_Record_Type_To_Purchase_Order</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Wild Desert Amended PO Approval Process</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>true</useApproverFieldOfRecordOwner>
        <userHierarchyField>approver__c</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>2</processOrder>
    <recallActions>
        <action>
            <name>Email_Alert_PO_Recalled</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Recall_Status_Update</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>false</showApprovalHistory>
