<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>creator</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Item_Name_Formula__c</field>
        <field>Status__c</field>
        <field>Item__c</field>
        <field>Source_Store__c</field>
        <field>Quantity__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>Purchase_Request_Approver__c</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Purchase_Request__c.Status__c</field>
                <operation>equals</operation>
                <value>For Approval</value>
            </criteriaItems>
            <criteriaItems>
                <field>Purchase_Request__c.Purchase_Request_Approver__c</field>
                <operation>notEqual</operation>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>RejectRecord</ifCriteriaNotMet>
        <label>For Approval</label>
        <name>Step_1</name>
    </approvalStep>
    <emailTemplate>PR_Approval_Email_Templates/New_Purchase_Request_Approval_Template</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Purchase_Request__c.Status__c</field>
            <operation>equals</operation>
            <value>For Approval</value>
        </criteriaItems>
        <criteriaItems>
            <field>Purchase_Request__c.New_Item_Formula__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <criteriaItems>
            <field>Purchase_Request__c.Send_Directly_To_Order__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <criteriaItems>
            <field>Purchase_Request__c.Is_Source_Non_Inventory_Item__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Update_For_Allocation</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Purchase_Request_Rejected_Email_Alert</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_Rejected_Status</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>PR_Approval_Email_1</name>
            <type>Alert</type>
        </action>
    </initialSubmissionActions>
    <label>Purchase Request Approval Process</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
