<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>PO_Requested_By__c</field>
        <field>Old_Total_Tax_10__c</field>
        <field>Amendment_Amount_Currency__c</field>
        <field>Old_Total_Tax_exc__c</field>
        <field>Recharge_Invoice_del__c</field>
        <field>biz3__Total_exc_Tax__c</field>
        <field>biz3__Total_inc_Tax__c</field>
        <field>biz3__Contact__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <description>This Approval process is created to handle PO Amendment if total PO price less than 10% or $500 which is lower</description>
        <entryCriteria>
            <formula>OR( Amendment_Amount_Currency__c &lt;= 500,
 (Amendment_Amount_Currency__c / biz3__Total_inc_Tax__c) &lt;= 0.10
)</formula>
        </entryCriteria>
        <ifCriteriaNotMet>GotoNextStep</ifCriteriaNotMet>
        <label>All under 500</label>
        <name>All_under_500</name>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>josh.doig@wilddesert.com.au</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <description>Handles PO Amendment if Amendment amount is greater than $500 or greater than 10% increase</description>
        <entryCriteria>
            <formula>OR( Amendment_Amount_Currency__c &gt; 500,
(Amendment_Amount_Currency__c / biz3__Total_inc_Tax__c) &gt; 0.10
)</formula>
        </entryCriteria>
        <label>All over 500</label>
        <name>All_over_500</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <description>This Approval process is created to handle PO Amendment</description>
    <emailTemplate>Purchase/Purchase_Order_Approvals_Request</emailTemplate>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>biz3__Purchase_Order__c.biz3__Status__c</field>
            <operation>equals</operation>
            <value>Amendment</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Update_PO_Record_Type_to_Approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Update_PO_Status_to_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Purchase_Order_Not_Apporved</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_PO_Status_to_Not_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>true</finalRejectionRecordLock>
    <label>PO Approval Process_2</label>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>true</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <processOrder>2</processOrder>
    <recallActions>
        <action>
            <name>Update_PO_Status_to_recalled</name>
            <type>FieldUpdate</type>
        </action>
    </recallActions>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
