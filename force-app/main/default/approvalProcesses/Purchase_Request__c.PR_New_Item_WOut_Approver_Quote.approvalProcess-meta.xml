<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>creator</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Item_Name_Formula__c</field>
        <field>Status__c</field>
        <field>Quantity__c</field>
        <field>Cost_Allocation_Unit__c</field>
        <field>Cost_Price_GST_exc__c</field>
        <field>Destination_Store__c</field>
        <field>Total_Cost_Price_GST_exc__c</field>
        <field>Notes__c</field>
        <field>Work_Order__c</field>
        <field>Supplier__c</field>
        <field>Asset__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>purchasing@wilddesert.com.au</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <entryCriteria>
            <criteriaItems>
                <field>Purchase_Request__c.Status__c</field>
                <operation>equals</operation>
                <value>For Item Approval</value>
            </criteriaItems>
        </entryCriteria>
        <ifCriteriaNotMet>ApproveRecord</ifCriteriaNotMet>
        <label>For Item Approval</label>
        <name>For_Item_Approval</name>
    </approvalStep>
    <emailTemplate>PR_Approval_Email_Templates/New_Purchase_Request_Approval_Template</emailTemplate>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <booleanFilter>1 AND 2 AND (3 OR 4) AND 5</booleanFilter>
        <criteriaItems>
            <field>Purchase_Request__c.Status__c</field>
            <operation>equals</operation>
            <value>For Approval</value>
        </criteriaItems>
        <criteriaItems>
            <field>Purchase_Request__c.New_Item_Formula__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <criteriaItems>
            <field>Purchase_Request__c.Purchase_Request_Approver__c</field>
            <operation>equals</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Purchase_Request__c.Is_Submitter_the_Approver__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <criteriaItems>
            <field>Purchase_Request__c.Quoted_Cost_Price__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Tag_as_For_Order</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>Update_For_Ordering</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Purchase_Request_Rejected_Email_Alert</name>
            <type>Alert</type>
        </action>
        <action>
            <name>Update_Rejected_Status</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Update_For_Item_Approval</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>PR - New Item WOut Approver - Quote</label>
    <processOrder>4</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
