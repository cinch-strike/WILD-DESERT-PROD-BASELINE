    <rules>
        <fullName>Update Site End Date WFR</fullName>
        <actions>
            <name>Update_Site_End_Date_WFU</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>AND( PRIORVALUE( Site_Active__c ) = true, Site_Active__c = false,  NOT( ISBLANK( Contract__c ) )  )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Update Site Name on Previous Site</fullName>
        <actions>
            <name>Update_Site_Name_on_Previous_Site_WFU</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>NOT(ISBLANK(Previous_Site_Look_up__c)) &amp;&amp;  Site_Active__c &amp;&amp;  NOT( ISBLANK( Contract__c ) )</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Update Site Start Date WFR</fullName>
        <actions>
            <name>Update_Site_Start_Date_WFU</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>Site_Active__c &amp;&amp;  NOT( ISBLANK( Contract__c ) )</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Update Site Status Open Inactive WFR</fullName>
        <actions>
            <name>Update_Site_Status_Open_Inactive_FU</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Updates Site Status to Open - Inactive when Site marked Inactive</description>
        <formula>IF( AND( PRIORVALUE(Site_Active__c) = true, Site_Active__c = false ), true, false ) &amp;&amp;  NOT( ISBLANK( Contract__c ) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Update Site to Open</fullName>
        <actions>
            <name>Update_Site_to_Open_WFU</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Site__c.Site_Active__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
</Workflow>
