    <decisions>
        <name>Check_Quantity_Received</name>
        <label>Check Quantity Received</label>
        <locationX>314</locationX>
        <locationY>1271</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Update_PO_Item</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Unknown</defaultConnectorLabel>
        <rules>
            <name>Received_Less_than_Expected_Quantity</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>intNoOfItems</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>$Record.Quantity__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.No_of_Items_Received__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Partially_Fulfilled</targetReference>
            </connector>
            <label>Received Less than Expected Quantity</label>
        </rules>
        <rules>
            <name>Received_Equal_To_Quantity</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>intNoOfItems</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Quantity__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Fulfilled</targetReference>
            </connector>
            <label>Received Equal To Quantity</label>
        </rules>
    </decisions>
