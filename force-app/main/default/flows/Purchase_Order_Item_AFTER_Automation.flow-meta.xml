        <locationX>842</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Not Applicable</defaultConnectorLabel>
        <rules>
            <name>Yes_withPR</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.PO_Item_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Non-PR Related</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.PO_Item_Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Parent_Purchase_Order</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
        <rules>
            <name>Cancelled_PO_Item</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.PO_Item_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_PO_Item_Cancelled</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Cancelled PO Item</label>
        </rules>
        <rules>
            <name>Non_PR_Related</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.PO_Item_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Non-PR Related</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_PO_Item_Non_PR</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Non-PR Related</label>
        </rules>
    </decisions>
    <description>25 JULY 2022: Changed intNoOfItems to decimal(2)</description>
    <environments>Default</environments>
    <formulas>
        <name>intNoOfItems</name>
        <dataType>Number</dataType>
        <expression>{!$Record.No_of_Items_Received__c} + {!$Record.No_of_Items_Cancelled__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>intTaxRate</name>
        <dataType>Number</dataType>
        <expression>IF( ISPICKVAL( {!$Record.Tax_Code__c}, &apos;GST Free Expenses&apos;), 0, 10)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>intTotalPrice</name>
        <dataType>Currency</dataType>
        <expression>IF(ISPICKVAL({!$Record.Tax_Code__c}, &apos;GST on Expenses&apos;), (({!$Record.Cost_Price__c} * {!$Record.Tax_Rate__c}) + {!$Record.Cost_Price__c}) * {!$Record.Quantity__c} , {!$Record.Cost_Price__c} * {!$Record.Quantity__c})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>isNewRecord</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>txtTaxCode</name>
        <dataType>String</dataType>
        <expression>IF(ISNULL({!$Record.Inventory_Item__c}), IF(ISPICKVAL({!$Record.Tax_Code__c}, &apos;&apos;), &apos;GST on Expenses&apos;, TEXT({!$Record.Tax_Code__c})), TEXT({!$Record.Inventory_Item__r.Tax_Code__c}))</expression>
    </formulas>
