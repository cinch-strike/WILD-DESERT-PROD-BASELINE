    <formulas>
        <name>htmlQuoteItem_ItemMaster</name>
        <dataType>String</dataType>
        <expression>&quot;&lt;tr&gt;    &lt;td style=&apos;text-align:left;border:1px solid;padding: 5px;&apos;&gt;&quot; + {!Loop_each_Item_Master.Name} + &quot;&lt;/td&gt;  &lt;td style=&apos;text-align:left;border:1px solid;padding: 5px;&apos;&gt;&quot; + {!Loop_each_Item_Master.Supplier_Part_Number__c} + &quot;&lt;/td&gt;    &lt;td style=&apos;text-align:left;border:1px solid;padding: 5px;&apos;&gt;&quot; + TEXT({!Loop_each_Item_Master.Cost_Category__c}) + &quot;&lt;/td&gt;&lt;td style=&apos;text-align:center;border:1px solid;padding: 5px;&apos;&gt;1&lt;/td&gt;&lt;td style=&apos;text-align:right;border:1px solid;padding: 5px;&apos;&gt;&quot; + {!txtCostPrice_ItemMaster} + &quot;&lt;/td&gt;&lt;td style=&apos;text-align:right;border:1px solid;padding: 5px;&apos;&gt;&quot; + {!txtCostPrice_ItemMaster} + &quot;&lt;/td&gt;  &lt;/tr&gt;&quot;</expression>
    </formulas>
    <formulas>
