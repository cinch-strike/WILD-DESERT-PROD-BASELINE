    </formulas>
    <formulas>
        <name>txtCostPrice_ItemMaster</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Loop_each_Item_Master.Cost_Price__c}), &quot;&quot;, &quot;$&quot; + IF(LEN(TEXT(FLOOR({!Loop_each_Item_Master.Cost_Price__c}))) &gt; 3, LEFT(TEXT(FLOOR({!Loop_each_Item_Master.Cost_Price__c})), LEN(TEXT(FLOOR({!Loop_each_Item_Master.Cost_Price__c}))) - 3) + &quot;,&quot; + RIGHT(TEXT(FLOOR({!Loop_each_Item_Master.Cost_Price__c})),3), TEXT(FLOOR({!Loop_each_Item_Master.Cost_Price__c}))) + &quot;.&quot; + LPAD(TEXT(({!Loop_each_Item_Master.Cost_Price__c}-FLOOR({!Loop_each_Item_Master.Cost_Price__c}))*100),2,&quot;0&quot;))</expression>
