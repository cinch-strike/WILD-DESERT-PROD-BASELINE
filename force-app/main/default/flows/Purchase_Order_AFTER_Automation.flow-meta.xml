                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_PO_Approver</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>25 JULY 2022: Changed variable intTotal_Fulfilled_NonPRRelated_Quantity to decimal(2)</description>
    <environments>Default</environments>
    <formulas>
        <name>curPriceLimit</name>
        <dataType>Currency</dataType>
        <expression>IF({!$Record.Total_Price_inc_GST_rollup__c} &gt; 15000, 15000, 10000)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>FORMULA_PO_Is_New</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>intTotal_Fulfilled_NonPRRelated_Quantity</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Total_Quantity_Fulfilled__c} + {!$Record.Total_Non_PR_Related_Quantity__c} + {!$Record.Total_Quantity_Cancelled__c}</expression>
        <scale>2</scale>
    </formulas>
