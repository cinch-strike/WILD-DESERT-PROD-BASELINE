    <decisions>
        <name>has_Open_Driver_Assignment</name>
        <label>has Open Driver Assignment</label>
        <locationX>182</locationX>
        <locationY>995</locationY>
        <defaultConnector>
            <targetReference>Update_Open_Driver_Assignment_FALSE</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>NO</defaultConnectorLabel>
        <rules>
            <name>YES_openDA</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Check_Open_Driver_Assignments</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Open_Driver_Assignment_TRUE</targetReference>
            </connector>
            <label>YES</label>
        </rules>
    </decisions>
    <decisions>
        <name>is_new_TJ_OR_Description_changed</name>
        <label>new TJ OR Description changed?</label>
        <locationX>182</locationX>
        <locationY>587</locationY>
        <defaultConnector>
            <targetReference>Check_Open_Driver_Assignments</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>NO</defaultConnectorLabel>
        <rules>
            <name>YES_DescriptionChanged</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Description__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>newTransportJob</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_TJ_Description</targetReference>
            </connector>
            <label>YES</label>
        </rules>
    </decisions>
    <decisions>
        <name>new_TJ_OR_Category_changed</name>
        <label>new TJ OR Category changed?</label>
        <locationX>182</locationX>
        <locationY>287</locationY>
        <defaultConnector>
            <targetReference>is_new_TJ_OR_Description_changed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>NO</defaultConnectorLabel>
        <rules>
            <name>Yes_NewChanged</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Category__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>newTransportJob</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Billable_checkbox</targetReference>
            </connector>
            <label>YES</label>
        </rules>
    </decisions>
    <description>30 OCT 2023: Added the auto population of TJ Description.</description>
    <environments>Default</environments>
    <formulas>
        <name>bolBillable</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISPICKVAL({!$Record.Category__c}, &apos;DSJ Required&apos;), TRUE, FALSE)</expression>
    </formulas>
    <formulas>
        <name>newTransportJob</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>strDescription</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!$Record.Description__c}) &gt; 255, LEFT({!$Record.Description__c}, 252) + &apos;...&apos;, {!$Record.Description__c})</expression>
    </formulas>
    <interviewLabel>Transport Job - BEFORE - Automation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Transport Job - BEFORE - Automation</label>
