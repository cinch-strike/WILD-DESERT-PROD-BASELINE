    <assignments>
        <name>Update_Open_Driver_Assignment_FALSE</name>
        <label>Update Open Driver Assignment = FALSE</label>
        <locationX>314</locationX>
        <locationY>1103</locationY>
        <assignmentItems>
            <assignToReference>$Record.Open_Driver_Assignment__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Update_Open_Driver_Assignment_TRUE</name>
        <label>Update Open Driver Assignment = TRUE</label>
        <locationX>50</locationX>
        <locationY>1103</locationY>
        <assignmentItems>
            <assignToReference>$Record.Open_Driver_Assignment__c</assignToReference>
            <operator>Assign</operator>
