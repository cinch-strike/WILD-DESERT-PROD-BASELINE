    <recordUpdates>
        <description>This will check Expired checkbox.</description>
        <name>mainUpdate</name>
        <label>mainUpdate</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Expired__c</field>
            <value>
                <booleanValue>true</booleanValue>
