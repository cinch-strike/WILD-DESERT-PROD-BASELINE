        <locationX>710</locationX>
        <locationY>1622</locationY>
        <defaultConnectorLabel>N/A</defaultConnectorLabel>
        <rules>
            <name>All_with_Suppliers</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
