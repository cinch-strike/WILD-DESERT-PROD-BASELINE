    <decisions>
        <name>is_Valid_User</name>
        <label>is Valid User?</label>
        <locationX>1172</locationX>
        <locationY>158</locationY>
        <defaultConnector>
            <targetReference>Assign_Invalid_User</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_ValidUser</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>strUserProfileName</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Purchasing</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>strUserProfileName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>System Administrator</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>strUserProfileName</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Finance</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_per_PR</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
