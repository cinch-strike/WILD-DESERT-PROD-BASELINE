<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Send_auto_email</name>
        <label>Send auto email</label>
        <locationX>469</locationX>
        <locationY>115</locationY>
        <actionName>Unit__c.NDT_Hours_3800_Email_Alert</actionName>
        <actionType>emailAlert</actionType>
        <connector>
            <targetReference>Assign_NDT_Email_Sent_True</targetReference>
        </connector>
        <inputParameters>
            <name>SObjectRowId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>Unit__c.NDT_Hours_3800_Email_Alert</nameSegment>
    </actionCalls>
    <apiVersion>50.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_NDT_Email_Sent_True</name>
        <label>Assign NDT Email Sent = True</label>
        <locationX>699</locationX>
        <locationY>115</locationY>
        <assignmentItems>
            <assignToReference>$Record.NDT_Email_Sent__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Rig_Unit</targetReference>
        </connector>
    </assignments>
    <description>Automation email for Rig records with NDT hours greater than 3800 hours</description>
    <interviewLabel>Schedule – NDT Automation Email {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Schedule – NDT Automation Email</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Rig_Unit</name>
        <label>Update Rig Unit</label>
        <locationX>951</locationX>
        <locationY>114</locationY>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>42</locationY>
        <connector>
            <targetReference>Send_auto_email</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>UnitType__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Rig</stringValue>
            </value>
        </filters>
        <filters>
            <field>NDT_Hours_Total__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <numberValue>3800.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>NDT_Email_Sent__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Unit__c</object>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2020-10-23</startDate>
            <startTime>08:00:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>varBodyText</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Please be advised that the NDT inspection will be due soon.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b&gt;Unit Name:&lt;/b&gt; {!$Record.Name}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b&gt;NDT Hours (Total): &lt;/b&gt;{!$Record.NDT_Hours_Total__c}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>varSubjectText</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;[Internal Alert] NDT Inspection - {!$Record.Name}&lt;/p&gt;</text>
    </textTemplates>
    <variables>
        <name>varRecipientEmail</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>projects@dbconsulting.co.nz</stringValue>
        </value>
    </variables>
</Flow>
