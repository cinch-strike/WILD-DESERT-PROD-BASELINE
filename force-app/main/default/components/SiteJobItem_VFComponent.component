            <script>
            $(document).ready(function() {rowbuttons();});
            
            function rowbuttons(){
                $('[id*="cont"]').dblclick(function(e){
                    
                    var rowid = $(this).parent().attr('id');
                    var parentId = rowid.split(':').slice(0, 4);
                    var savebtnId = parentId.join(':')+':saveButton';
                    var cancelbtnId = parentId.join(':')+':cancelButton';
                    var deletebtnId = parentId.join(':')+':deleteButton';
                    var inlineLookupId = parentId.join(':')+':inlineLookup';
                    var startIconId = parentId.join(':')+':startIcon';
                    var endIconId = parentId.join(':')+':endIcon';
                    var quantityIconId = parentId.join(':')+':quantityIcon';
                    if($('.inlineEditDiv').find('input').attr('onfocus')!=undefined && $('.inlineEditDiv').find('input').attr('onfocus').indexOf("DatePicker")>=0){
                        $('.inlineEditDiv').find('input[onfocus]').timepicker({
                            timeFormat: 'h:mm p',
                            interval: 15,
                            dynamic: false,
                            dropdown: true,
                            scrollbar: true,
                            change: function(time) {
                                var formattedDate = new Date('{!dr.Report_Date__c}');
                                var d = formattedDate.getDate();
                                var m =  formattedDate.getMonth();
                                m += 1;  // JavaScript months are 0-11
                                var y = formattedDate.getFullYear();
                                var datestring = d + "/" + m + "/" + y;
                                $(this)[0].value = datestring+ ' '+$(this).timepicker().format(time);
                            }
                        });
                    }
                    
                    document.getElementById(savebtnId) != null ? document.getElementById(savebtnId).style.display = "inline" : "";
                    document.getElementById(cancelbtnId) != null ? document.getElementById(cancelbtnId).style.display = "inline" : "";
                    document.getElementById(deletebtnId) != null ? document.getElementById(deletebtnId).style.display = "none" : "";
                    document.getElementById(inlineLookupId) != null ? document.getElementById(inlineLookupId).style.display = "inline" : "";
                    
                });
            }
            
            
            
            
            
            
            function passJobItemId(cjiId,cjiname,lookupClass,itmName,serviceType,wdAsst,wdAsstName){
                
                var jobItemName = document.getElementById(document.getElementsByClassName(lookupClass)[0].id);
                var jobItemId = document.getElementById(document.getElementsByClassName(lookupClass)[0].id+'_lkid');
                var jobItemId2 = document.getElementById(document.getElementsByClassName(lookupClass)[0].id+'_lkold');
                
                //jobItemId2.value = cjiname;
                jobItemId2.value = cjiname;
                jobItemName.value = cjiname;
                jobItemId.value = cjiId;
                
                document.getElementById(lookupClass).value = cjiname;
                
                $(jobItemName).closest('td').next('td').find('label').html(itmName)
                if(serviceType === 'Fixed Price/Hour'){
                    $(jobItemName).closest('tr').find('input.qty')[0].disabled = true;
                    $(jobItemName).closest('tr').find('input.startdate')[0].disabled = false;
                    $(jobItemName).closest('tr').find('input.enddate')[0].disabled = false;
                }
                else if(serviceType === 'Fixed Price/Quantity' || serviceType === 'Flexi Price/Quantity'){
                    $(jobItemName).closest('tr').find('input.startdate')[0].disabled = true;
                    $(jobItemName).closest('tr').find('input.enddate')[0].disabled = true;
                    $(jobItemName).closest('tr').find('input.qty')[0].disabled = false;
                }
                
                $(jobItemName).closest('tr').closest('tr').find('span.displayContractItem')[0].innerText = cjiname;
                $(jobItemName).closest('tr').find('div.typAhdComponent').hide();
                $(jobItemName).closest('tr').find('div.displayContractItemDiv').show();
                
                /*if(typeof(wdAsst) !== 'undefined'){
                    $(jobItemName).closest('tr').find('[id*="cont2"]')[0].innerText = wdAsstName;
                    $(jobItemName).closest('tr').closest('tr').find('.wdAssetDiv input')[0].value = wdAsst;
                }*/
                
                closeModal();
            }
            
            $(document).ready(function() {
                $('.cji1').DataTable({
                    "bPaginate": false,
                    "bFilter": true,
                    "bLengthChange" : false,
                    "bInfo" : true
                });
            });
            
            function focusAndupdateContact() {
                document.getElementById('focusMeupdateItem').click();
            }
            
            function applyLookup(){
                $('#tableinput2').children('lookupInput').find('input').addClass('slds-input');
            }
            
            function changeTab2(actn){
                var acton = actn;
                changeTabNow(acton);
            }
            
            function closeCancelDialog(){
                $('.closeDialog').removeClass( "slds-fade-in-open" ).addClass( "slds-fade-in-hide" );
                $('#createnewbackdrop').removeClass( "slds-backdrop--open" ).addClass( "slds-backdrop--hide" );
            }
            
            function inputLimiter(e,allow) {
                var AllowableCharacters = '';
                if (allow == 'Letters'){AllowableCharacters=' ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';}
                if (allow == 'Numbers'){AllowableCharacters='1234567890.';}
                if (allow == 'NameCharacters'){AllowableCharacters=' ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz-.\'';}
                if (allow == 'NameCharactersAndNumbers'){AllowableCharacters='1234567890 ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz-\'';}
                if (allow == 'Currency'){AllowableCharacters='1234567890.';}
                if (allow == 'Number'){AllowableCharacters = '1234567890';}
                var k = document.all?parseInt(e.keyCode): parseInt(e.which);
                if (k!=13 && k!=8 && k!=0){
                    if ((e.ctrlKey==false) && (e.altKey==false)) {
                        return (AllowableCharacters.indexOf(String.fromCharCode(k))!=-1);
                    } else {
                        return true;
                    }
                } else {
                    return true;
                }
            }
            
            
            </script>
