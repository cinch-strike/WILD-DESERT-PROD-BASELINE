    function deleteFunction(rcid){
        var deleteRecordId = rcid;
        deleteActionFunction{!SObjectAPI}(deleteRecordId);
    }

    $(document).ready(function() {

    $("table.datatablesort_{!sObjName}_{!relatedId}").each(function() {
    $(this).DataTable({
    "bPaginate": false,
    "bFilter": false,
    "bLengthChange" : false,
    "bInfo" : false
    });
    });



    console.log('headerColor');
        $('.sorting_asc').css({
            'background-color': "#dee4ed",
            'background-image':'none'
        });

        $('.sorting_desc').css({
            'background-color': "#f4f6f9",
            'background-image':'none'
         });

        $('.sorting').css({
            'background-color': "#ffffff",
            'background-image':'none'
        });

    });



    /*window.onload = function(){
        $('.oRight').removeClass('oRight');
        headerColor();
    }*/


    function headerColor(){
        console.log('headerColor');
        $('.sorting_asc').css({
            'background-color': "#dee4ed",
            'background-image':'none'
        });

        $('.sorting_desc').css({
            'background-color': "#f4f6f9",
            'background-image':'none'
         });

        $('.sorting').css({
            'background-color': "#ffffff",
            'background-image':'none'
        });

        }

    </script>


</apex:component>