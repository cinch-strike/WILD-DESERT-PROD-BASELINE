<apex:page standardController="WD_Report__c">
<apex:pageBlock >
<apex:variable var="v" value="'{!WD_Report__c.WD_Personnel__r}'"/>
<apex:variable var="v2" value="'[]'"/>

<apex:outputPanel rendered="{!v == v2}">
 No records to display
</apex:outputPanel>

<apex:pageBlockTable value="{!WD_Report__c.WD_Personnel__r}" var="item" rendered="{! NOT(v == v2)}">


<apex:column value="{!item.Name}"/>
<apex:column value="{!item.Date_Created__c}"/>
<apex:column value="{!item.Pay_Ending__c}"/>

<apex:column headerValue="Name">
<apex:outputLink value="/{!item.Name__c}" target="_top">{!item.Name__r.Name}</apex:outputLink>                         
</apex:column>

<apex:column headerValue="Position">
<apex:outputLink value="/{!item.Position__c}" target="_top">{!item.Position__r.Name}</apex:outputLink>                         
</apex:column>

<apex:column value="{!item.Night_Shift__c}"/>
<apex:column value="{!item.Total_Hours__c}"/>
<apex:column value="{!item.Crew_Change_Day__c}"/>


</apex:pageBlockTable>

</apex:pageBlock>


</apex:page>