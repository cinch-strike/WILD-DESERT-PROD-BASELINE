<!-----------------------------------WD Fuel Management---------------------------------------------------->

<apex:pageblockSection title="General" columns="2" collapsible="false"  rendered="{!NOT(OR (WDPageRecordType  == 'Transport', WDPageRecordType  == 'Transport (Approved)'))}" >

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Weather:"/>
 <apex:inputField value="{!WDR.Weather__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="Fuel Used:"/>
 <apex:inputField value="{!WDR.Fuel_Used__c}" />
</apex:pageBlockSectionItem>


<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="Camp:"/>
 <apex:inputField value="{!WDR.Camp__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="Fuel Delivered:"/>
 <apex:inputField value="{!WDR.Fuel_Delivered__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="Fuel on Hand:"/>
 <apex:outputField value="{!WDR.Fuel_On_Hand__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="Line on Spool:"/>
 <apex:inputField value="{!WDR.Line_on_Spool__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem > 
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="Line Slipped:"/>
 <apex:inputField value="{!WDR.Line_Slipped__c}" />
</apex:pageBlockSectionItem>


<apex:pageBlockSectionItem >
 <apex:outputLabel value="Pay Ending Date:"/>
  <apex:selectList value="{!selectedPayEnding}" multiselect="false" size="1" >
        <apex:selectOptions value="{!PayEndingList}" />
  </apex:selectList>
</apex:pageBlockSectionItem>


</Apex:pageblockSection>

<!-----------------------------------WD Safety---------------------------------------------------->
<apex:pageblockSection title="Safety Data" columns="2" collapsible="false"  rendered="{!NOT(OR (WDPageRecordType  == 'Transport', WDPageRecordType  == 'Transport (Approved)'))}" >

<apex:pageBlockSectionItem >
 <apex:outputLabel value="LTI Free Days:"/>
 <apex:inputField value="{!WDR.LTI_Free_Days__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Hazards Raised:"/>
 <apex:inputField value="{!WDR.Hazards_Raised__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="TBM:"/>
 <apex:inputField value="{!WDR.TBM__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Safety Meetings:"/>
 <apex:inputField value="{!WDR.Safety_Meetings__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="SOP Review:"/>
 <apex:inputField value="{!WDR.SOP_Review__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Emergency Drill:"/>
 <apex:inputField value="{!WDR.Emergency_Drill__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR (WDPageRecordType  == 'Remote Camp', WDPageRecordType  == 'Remote Camp (Approved)'))}" >
 <apex:outputLabel value="Permit to Work:"/>
 <apex:inputField value="{!WDR.Permit_to_Work__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Inductions Employee:"/>
 <apex:inputField value="{!WDR.Inductions_Employee__c}" />
</apex:pageBlockSectionItem>


</Apex:pageblockSection>

</apex:outputPanel>


</apex:pageBlock>


<!-----------------------------------WD Personnel Component---------------------------------------------------->
<c:skedWDPersonnel PersonnelList="{!PersonnelList}" WDPpageController="{!this}" componentKey="component1" rendered="{!NOT(OR (WDPageRecordType  == 'Transport', WDPageRecordType  == 'Transport (Approved)'))}" />


<!-----------------------------------WD Services Received---------------------------------------------------->
<c:skedWDServiceReceived WDSRWrappers="{!WDSRWrapperList}" WDPpageController="{!this}" componentKey="component3" />


<apex:commandButton value="Save All" action="{!WDRSavePage}"/><apex:commandButton value="Cancel" action="{!Cancel}" immediate="true"/>

</apex:form>
</apex:page>