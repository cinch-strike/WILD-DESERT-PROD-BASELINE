<apex:page controller="skedWDPageController" docType="html-5.0">


<apex:form >
   <apex:pageMessages />


<!---------------------------------------WD Report --------------------------------------------------------->

<apex:pageBlock title="WD Report">

<!---------------------------------------WD Report 12 Hour Rig Information--------------------------------------------------------->
<apex:outputPanel >
<apex:pageblockSection title="WD Report Detail" columns="2" collapsible="false" >

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Job Order #:"/>
 <!--<apex:outputText >{!JobOrderId}</apex:outputText>-->
 <apex:inputField value="{!WDR.Sales_Order__c}" required="true" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Record Type:"/>
 <apex:outputPanel >
 <apex:outputText value="{!WDPageRecordType}" />
   </apex:outputPanel>
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!NOT(OR ('Transport' == WDPageRecordType, 'Transport (Approved)' == WDPageRecordType))}" >
 
  <apex:outputLabel value="WD Report #:"/>
 <apex:inputField value="{!WDR.Hard_Copy__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem rendered="{!OR ('Transport' == WDPageRecordType, 'Transport (Approved)' == WDPageRecordType)}" >
<apex:outputLabel value="Truck docket #:"/>
 <apex:inputField value="{!WDR.Hard_Copy__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem > 
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem > 
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="WD Unit:"/>
 <apex:inputField value="{!WDR.WD_Unit__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Date:"/>
 <apex:inputField value="{!WDR.Date__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Site:"/>
 <apex:inputField value="{!WDR.Site__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Job Description:"/>
 <apex:inputField value="{!WDR.Job_Description__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Client:"/>
 <apex:inputField value="{!WDR.Client__c}" />
</apex:pageBlockSectionItem>

<apex:pageBlockSectionItem >
 <apex:outputLabel value="Status:"/>
 <apex:inputField value="{!WDR.Status__c}" />
</apex:pageBlockSectionItem>


<apex:pageBlockSectionItem >
 <apex:outputLabel value="Approved By:"/>
 
 <apex:outputPanel styleClass="requiredInput" layout="block" >
<apex:outputPanel styleClass="requiredBlock" layout="block"/>
 <apex:inputField value="{!WDR.Approved_By__c}" />
</apex:outputPanel>

</apex:pageBlockSectionItem>
    

</Apex:pageblockSection>

<!---------------------------------------WD Report Transport Details--------------------------------------------------------->

<apex:pageblockSection title="Transport Details" columns="1" collapsible="false"  rendered="{!OR (WDPageRecordType  == 'Transport',  WDPageRecordType  == 'Transport (Approved)')}" >


<apex:pageBlockSectionItem >
 <apex:outputLabel value="Truck on Job:"/>
  <apex:selectList value="{!WDR.Trucks_on_Job__c}" multiselect="true" size="4" >
        <apex:selectOptions value="{!TruckList}" />
  </apex:selectList>
</apex:pageBlockSectionItem>

</Apex:pageblockSection>



