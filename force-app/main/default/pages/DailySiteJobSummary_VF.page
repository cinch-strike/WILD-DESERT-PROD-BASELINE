    <script>
    
    $(document).ready(function() {
        if($('span').hasClass('twitter-typeahead')){
            $('table.siteJobItemTable tr:last-child').hide();
        }
    });
    
    
    function changeTab(thisObj){
        var siblingAnchorElementId = thisObj.siblings('li.slds-is-active').find('a').attr('id');
        var siblingtabElement = "[aria-labelledby=" + siblingAnchorElementId + "]";
        //$(siblingtabElement).removeClass("slds-show");
        //$(siblingtabElement).addClass("slds-hide");
        $(siblingtabElement).toggleClass("slds-show");
        $(siblingtabElement).toggleClass("slds-hide");
        
        
        thisObj.addClass('slds-is-active');
        thisObj.find('a').attr('aria-selected', true);
        thisObj.siblings().removeClass('slds-is-active');
        thisObj.siblings().find('a').attr('aria-selected', false);
        
        var anchorElementId = thisObj.find('a').attr('id');
        var tabElement = "[aria-labelledby=" + anchorElementId + "]";
        //$(tabElement).addClass("slds-show");
        $(tabElement).toggleClass("slds-show");
        $(tabElement).toggleClass("slds-hide");
        
    }
    
    $('.slds-tabs_default__item').on('click', function(){
        changeTab($(this));
    });
    
    
    $('.slds-tabs_scoped__item').on('click', function(){
        changeTab($(this));
    });
    
    function closeCancelDialog(){
        /*$('.closeDialog').removeClass( "slds-fade-in-open" ).addClass( "slds-fade-in-hide" );
        $('#createnewbackdrop').removeClass( "slds-backdrop--open" ).addClass( "slds-backdrop--hide" );*/
        closeApprovalModal();
    }
    
    
    
    </script>
    
