<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>InTransit_MissingManifest</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL( Status__c , &apos;In Transit&apos;),
    ISBLANK( Manifest_No__c ) 
)</errorConditionFormula>
    <errorDisplayField>Manifest_No__c</errorDisplayField>
    <errorMessage>Please specify the Manifest Number.</errorMessage>
</ValidationRule>
