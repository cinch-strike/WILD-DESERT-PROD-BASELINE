<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ByPassOrdering_SourceStoreRequired</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
   By_pass_Ordering__c = TRUE,
   ISBLANK( Source_Store__c ) 
)</errorConditionFormula>
    <errorDisplayField>Source_Store__c</errorDisplayField>
    <errorMessage>Source Store is required if Bypass Ordering is ticked.</errorMessage>
</ValidationRule>
