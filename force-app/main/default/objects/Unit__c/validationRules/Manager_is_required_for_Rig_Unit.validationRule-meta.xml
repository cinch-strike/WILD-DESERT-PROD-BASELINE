<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Manager_is_required_for_Rig_Unit</fullName>
    <active>false</active>
    <errorConditionFormula>AND(UnitType__c = &apos;Rig&apos;,ISBLANK( Manager__c ))</errorConditionFormula>
    <errorDisplayField>Manager__c</errorDisplayField>
    <errorMessage>A Manager must be assigned to a Rig Unit.</errorMessage>
</ValidationRule>
