<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MaintenanceCategory_Required</fullName>
    <active>false</active>
    <description>Maintenance category is required for maintenance job.</description>
    <errorConditionFormula>AND(
   ISPICKVAL(Transport_Job__r.Types__c, &apos;Maintenance&apos;),
   ISBLANK(TEXT( Maintenance_Category__c )) 
)</errorConditionFormula>
    <errorDisplayField>Maintenance_Category__c</errorDisplayField>
    <errorMessage>Maintenance category is required for maintenance job.</errorMessage>
</ValidationRule>
