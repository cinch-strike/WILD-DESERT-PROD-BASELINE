<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TDR_valid_for_Auto_Refresh_formula__c</fullName>
    <description>This field is used in FLOW automation. Set to TRUE if within 30days.</description>
    <formula>IF((TODAY() -  Report_Date__c) &lt; 31, TRUE, FALSE)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>TDR valid for Auto-Refresh</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
