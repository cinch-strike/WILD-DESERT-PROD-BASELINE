<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Cant_change_Report_Date_Once_Created</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
NOT(ISNEW()),
ISCHANGED(Report_Date__c) 
)</errorConditionFormula>
    <errorMessage>You cannot change Daily Site Job&apos;s Report Date once created</errorMessage>
</ValidationRule>
