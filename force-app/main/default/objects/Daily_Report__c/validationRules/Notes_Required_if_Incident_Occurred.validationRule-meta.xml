<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Notes_Required_if_Incident_Occurred</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
 Incident_Occurred__c,
 ISBLANK(Incident_Notes__c) 
)</errorConditionFormula>
    <errorDisplayField>Incident_Notes__c</errorDisplayField>
    <errorMessage>Kindly, fill out the details for the incident occurred.</errorMessage>
</ValidationRule>
