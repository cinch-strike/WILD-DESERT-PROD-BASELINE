<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Training_Completion_Tolerance__c</fullName>
    <description>This date = Created Date + 2 Months Tolerance</description>
    <formula>DATE(
  YEAR(DATEVALUE(Date_Created_Text__c)) + FLOOR((MONTH(DATEVALUE(Date_Created_Text__c)) + 2 - 1) / 12),
  MOD(MONTH(DATEVALUE(Date_Created_Text__c)) + 2 - 1, 12) + 1,
  DAY(DATEVALUE(Date_Created_Text__c))
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>This date = Created Date + 2 Months Tolerance</inlineHelpText>
    <label>Training Completion Tolerance</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Date</type>
</CustomField>
