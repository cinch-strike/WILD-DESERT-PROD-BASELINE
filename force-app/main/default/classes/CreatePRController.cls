        String query = 'Select Id,Inventory_Item__r.Name,Stock_Available_formula__c,Store_Item_Code__c, '+fieldName+' FROM Store_Item__c WHERE Store_Unit__r.Name = \'Roma Base Camp\' AND Inventory_Item__r.Name LIKE \'%' + value + '%\' OR Store_Item_Code__c LIKE \'%' + value + '%\'';
        system.debug(query);
