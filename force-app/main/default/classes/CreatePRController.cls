    @AuraEnabled
    public static void submitForApproval(List<Purchase_Request__c> prsToSubmit){
        List<Purchase_Request__c> prListToUpdate = new List<Purchase_Request__c>();
        for (Purchase_Request__c eachPR : prsToSubmit){
                Purchase_Request__c tempPr = new Purchase_Request__c();
                tempPr.id = eachPr.id;
                tempPr.Status__c = 'For Approval';
                prListToUpdate.add(tempPr);
                
        }
        update prListToUpdate;
    }
    
    @AuraEnabled
    public static purchaseUnitsWrapper fetchDraftPRs(){
        String UserId = UserInfo.getUserId();
        List<Unit__c> unitRec = [Select Id, Name,Purchase_Request_Approver__c FROM Unit__c WHERE Unit_Manager__c   =: UserId];
        /*Store_Item__c storeItem = [Select Id,Inventory_Item__r.Name,Inventory_Item__c,Stock_Available_formula__c,Store_Unit__r.Name  FROM Store_Item__c WHERE ID =: recId];
        List<Store_Item__c> storeItemsRecord = [Select Id,Name,Inventory_Item__r.Name,Inventory_Item__c,Stock_Available_formula__c,Store_Unit__r.Name,Store_Unit__c  FROM Store_Item__c 
            WHERE Inventory_Item__c =: storeItem.Inventory_Item__c AND Stock_Available_formula__c > 0];*/
        
        List<Purchase_Request__c> prList = [SELECT Id, Name, Item_Name_Formula__c, Source_Store__r.Name, Destination_Store__r.Name, Status__c, Quantity__c
                              FROM Purchase_Request__c 
                              WHERE CreatedById = :UserInfo.getUserId()
                              AND Status__c = 'Draft'
                              ];
        purchaseUnitsWrapper purchaseUnitWrap = new purchaseUnitsWrapper();
        if(unitRec.isEmpty()){
            List<Unit__c> allUnitList = [Select Id, Name FROM Unit__c WHERE RecordType.Name = 'Location' and Status__c = 'Active' ORDER BY Name];
            purchaseUnitWrap.prList = prList;
            purchaseUnitWrap.allUnitList = allUnitList;
        }else{
            purchaseUnitWrap.prList = prList;
        }                                
        return purchaseUnitWrap;
    }
    
