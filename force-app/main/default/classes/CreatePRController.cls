        for(sObject so : Database.Query('Select Id, Store_Item_Code__c, Name FROM Inventory_Item__c WHERE Active__c = TRUE AND Non_Searchable_Item__c = FALSE AND Name LIKE \'%' + value + '%\'')) { 
            returnList.add(so);
            String fieldvalue = (String)so.get(fieldName);
            sObjectResultList.add(new SObjectResult(fieldvalue, so.Id));
        }
        
        return returnList;
    }
    
