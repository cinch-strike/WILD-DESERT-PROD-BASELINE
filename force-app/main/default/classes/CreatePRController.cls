    @auraEnabled
    public static PurchaseRequestWrapper createPR(Integer Qty , Store_Item__c unitRecords,String storeName, String staffName,String DestinationStore,String itemName){
        String UserId = UserInfo.getUserId();
        List<Unit__c> unitRec = [Select Id, Name,Purchase_Request_Approver__c FROM Unit__c WHERE Unit_Manager__c   =: UserId];

        system.debug('unitRec'+unitRec);
        //[VP 19/11] Added logic for non-inventory item
        if(storeName == 'undefined'){
            Inventory_Item__c masterItem = [Select Id, Name FROM Inventory_Item__c WHERE Active__c = TRUE AND Name =: itemName limit 1];
            Store_Item__c sourceStoreItem = [select Id, Store_Unit__c from Store_Item__c where Inventory_Item__r.Name = 'NON-INVENTORY ITEM' limit 1];

            Purchase_Request__c pr = new Purchase_Request__c ();
            pr.Status__c = 'Draft';
            if(!unitRec.isEmpty()){
                pr.Destination_Store__c  = unitRec[0].id;
                pr.Purchase_Request_Approver__c  = unitRec[0].Purchase_Request_Approver__c;
            }
            else if(DestinationStore != ''){
                pr.Destination_Store__c  = DestinationStore;
            }
            pr.Source_Store_Item__c = sourceStoreItem.Id;
            pr.Item__c =masterItem.Id;
            pr.Quantity__c = Qty;
            pr.Staff_Name__c = staffName;
            insert pr;
            system.debug('## pr inserted: ' + pr);
            PurchaseRequestWrapper wrapObj = new PurchaseRequestWrapper();
            wrapObj.selected = false;
            wrapObj.pr = pr;
            wrapObj.created = false;
            return wrapObj;
     

        }else if(storeName != 'Roma Base Camp'){
            Purchase_Request__c pr = new Purchase_Request__c ();
            if(unitRec.size() > 0 ){
                pr.Status__c = 'Completed';
            }
            if(unitRec[0].id != null){
            	pr.Destination_Store__c  = unitRec[0].id;
            }else if(DestinationStore != ''){
                pr.Destination_Store__c  = DestinationStore;
            }
            pr.Purchase_Request_Approver__c  = unitRec[0].Purchase_Request_Approver__c;
            pr.Source_Store__c = unitRecords.Store_Unit__c;
            pr.Source_Store_Item__c = unitRecords.Id;
            pr.New_Item_Name__c = unitRecords.Inventory_Item__r.Name;
            pr.Item__c =unitRecords.Inventory_Item__c;
            pr.Staff_Name__c = staffName;
            pr.Quantity__c = Qty;
            insert pr;

            PurchaseRequestWrapper wrapObj = new PurchaseRequestWrapper();
            wrapObj.selected = false;
            wrapObj.pr = pr;
            wrapObj.created = true;
            wrapObj.storeName = storeName;
            return wrapObj;
        }else{
            Purchase_Request__c pr = new Purchase_Request__c ();
            pr.Status__c = 'Draft';
            if(!unitRec.isEmpty()){
                pr.Destination_Store__c  = unitRec[0].id;
                pr.Purchase_Request_Approver__c  = unitRec[0].Purchase_Request_Approver__c;
            }else if(DestinationStore != ''){
                pr.Destination_Store__c  = DestinationStore;
            }
            pr.New_Item_Name__c = unitRecords.Inventory_Item__r.Name;
            pr.Item__c = unitRecords.Inventory_Item__c;
            pr.Source_Store__c = unitRecords.Store_Unit__c;
            pr.Source_Store_Item__c = unitRecords.Id;
            pr.Staff_Name__c = staffName;
            pr.Quantity__c = Qty;
            insert pr;
            PurchaseRequestWrapper wrapObj = new PurchaseRequestWrapper();
            wrapObj.selected = false;
            wrapObj.pr = pr;
            wrapObj.created = false;
            wrapObj.storeName = storeName;
            return wrapObj;
        }
    }
    
    @AuraEnabled
    public static PurchaseRequestWrapper noItemPRCreate(Integer Qty , String itemName,String staffName,String DestinationStore){
        system.debug('## pr ino item created ' + itemName);
        String UserId = UserInfo.getUserId();
        List<Unit__c> unitRec = [Select Id, Name,Purchase_Request_Approver__c FROM Unit__c WHERE Unit_Manager__c   =: UserId];
        Store_Item__c sourceStoreItem = [select Id, Store_Unit__c from Store_Item__c where Inventory_Item__r.Name = 'ASSORTED ITEMS' limit 1];
        system.debug('unitRec'+unitRec);
        Purchase_Request__c pr = new Purchase_Request__c ();
        pr.Status__c = 'Draft';
        if(!unitRec.isEmpty()){
            pr.Destination_Store__c  = unitRec[0].id;
            pr.Purchase_Request_Approver__c  = unitRec[0].Purchase_Request_Approver__c;
        }
        else if(DestinationStore != ''){
            pr.Destination_Store__c  = DestinationStore;
        }
        pr.Source_Store__c = sourceStoreItem.Store_Unit__c;
        pr.Source_Store_Item__c = sourceStoreItem.Id;
        pr.New_Item_Name__c = itemName;
        pr.Quantity__c = Qty;
        pr.Staff_Name__c = staffName;
        insert pr;
        system.debug('## pr inserted: ' + pr);
        PurchaseRequestWrapper wrapObj = new PurchaseRequestWrapper();
        wrapObj.selected = false;
        wrapObj.pr = pr;
        wrapObj.created = false;
        return wrapObj;
    }
    
