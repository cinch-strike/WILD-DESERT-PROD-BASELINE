    public class PurchaseRequestWrapper {
        @AuraEnabled
        public Boolean selected;
        @AuraEnabled
        public Purchase_Request__c pr;
        @AuraEnabled
        public Boolean created;
        @AuraEnabled
        public String storeName;
        
        public PurchaseRequestWrapper() {
            this.selected = false;
            this.pr = null;
            this.created = false;
            this.storeName = '';
        }
    }
    
    public class purchaseUnitsWrapper{
        @AuraEnabled
        public List<Purchase_Request__c> prList;
