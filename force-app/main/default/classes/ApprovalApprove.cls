public without sharing class ApprovalApprove {
	@InvocableMethod(label='Approve a record')
	public static List<InvocableOutput> ApproveRecord(List<InvocableInput> inputList) {
		List<InvocableOutput> outputList = new List<InvocableOutput>();
        Set<Id> recordIdSet = new Set<Id>();
        Map<String, String> recordIdCommentMap = new Map<String, String>();
        for (InvocableInput input : inputList){
            recordIdCommentMap.put(input.recordId, input.approvalComments);
        }
        List<Id> newWorkItemIds = new List<Id>();
        Map<Id, String> networkItemIdTargetObjectIdMap = new Map<Id, String>();
        for (List<ProcessInstance> pis : [select Id, TargetObjectId, (select Id from WorkItems) from ProcessInstance where TargetObjectId in :recordIdCommentMap.keySet() and Status = 'Pending']) {
            for (ProcessInstance pi : pis) {
                for (List<ProcessInstanceWorkitem> wis : pi.Workitems) {
                    for (ProcessInstanceWorkitem wi : wis ) {
                        networkItemIdTargetObjectIdMap.put(wi.Id, pi.TargetObjectId);
                    }
                }           
            }
        }
        
        List<Approval.ProcessWorkitemRequest> reqList = new List<Approval.ProcessWorkitemRequest>();
        for (Id nwId : networkItemIdTargetObjectIdMap.keySet()){
            Approval.ProcessWorkitemRequest req = new Approval.ProcessWorkitemRequest();
            req.setAction('Approve');
            req.setWorkitemId(nwId);
            req.setComments(recordIdCommentMap.get(networkItemIdTargetObjectIdMap.get(nwId)));
            req.setNextApproverIds(new Id[] {UserInfo.getUserId()});
            reqList.add(req);
        }
        List<Approval.ProcessResult> approvalResults = new List<Approval.ProcessResult>();
        if (reqList.size() > 0){
            approvalResults = Approval.process(reqList, false);
        }
        for (Approval.ProcessResult result : approvalResults){
            InvocableOutput output = new InvocableOutput();
            output.success = result.isSuccess();
            outputList.add(output);
        }

        return outputList;

	}

    public class InvocableInput {
        @InvocableVariable(label='Record ID' required=true)
		public String recordId;

        @InvocableVariable(label='Comments')
		public String approvalComments;
    }

    public class InvocableOutput {
        @InvocableVariable(label='Success')
		public Boolean success;
    }

