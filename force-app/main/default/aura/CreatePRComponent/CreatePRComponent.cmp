                                              aura:id="checkid"/>
                            lightning:input type="checkbox" aura:id="{!hdtv}" name="input1" value="{!prRec.selected}"/ </div></td>
                        <td><div class="slds-truncate" >{!prRec.pr.New_Item_Name__c}</div></td>
                        <td><div class="slds-truncate" >{!prRec.pr.Status__c}</div></td>
                        <td><div class="slds-truncate" >
                            <lightning:input type="number" name="input1" value="{!prRec.pr.Quantity__c}" style="margin-top: -3%; !important"/></div></td>
                        <td><div class="slds-truncate" >{!prRec.storeName}</div></td>
                        <td><div class="slds-truncate" >
                            <a data-row-index="{!index}" onclick="{!c.removeRow}">
                   <lightning:icon variant="error" iconName="utility:delete" class="slds-icon slds-icon_small" size="small" alternativeText="icon"/>
                   <span class="slds-assistive-text">Delete Icon</span>
                  </a>
                            </div></td>
                    </tr>
                 </aura:iteration>
            </tbody>
        </table> -->
        <!-- the container element determine the height of the datatable -->
        <lightning:card title="Draft Purchase Requests" class="slds-card_boundary" iconName="standard:opportunity">
            <lightning:datatable data="{!v.prList}" 
                                 columns="{!v.prcolumns }" 
                                 keyField="Id"
                                 onrowselection="{!c.handleSelect}"
                                 onrowaction="{!c.handleRowAction}"
                                 />
        </lightning:card>
        <br/><br/>
        <lightning:button class="slds-button slds-button_outline-brand slds-align_absolute-center"
                          label="Save and Send for Approval"
                          title="Save and Send for Approval" 
                          disabled="{!empty(v.prList) }"
                          onclick="{!c.sendForApproval}"
                          />    
        <!--/aura:if-->
    </div>
</aura:component>