<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,force:lightningQuickAction" access="global" controller="CreatePRController" >
    <aura:attribute Name="selItem" type="object"  access="public" /> 
    <aura:attribute Name="qty" type="Integer"  access="public" /> 
    <aura:attribute Name="staffName" type="String"  access="public" /> 
    <aura:attribute Name="showSwitch" type="Boolean"  default="false" /> 
    <!--<aura:attribute Name="selectRecordId1" type="String"  /> -->
    <!--<aura:attribute Name="selectRecordName1" type="String"  /> -->
    <aura:attribute Name="unitRecords" type="Store_Item__c"/>
    <!--<aura:attribute Name="rig4Records" type="Store_Item__c"/>-->
    <!--<aura:attribute Name="isSecondScenario" type="Boolean" default="false"/>-->
    <aura:attribute Name="isCreatePR" type="Boolean" default="false"/>
    <aura:attribute Name="isNonIventoryItem" type="Boolean" default="false"/>
    
    <aura:attribute name="objectName" type="String" />
    <aura:attribute name="fieldName" type="String" default="Name"/>
    <aura:attribute name="selectRecordId" type="String"/>
    <aura:attribute name="selectAssetId" type="String"/>
    <aura:attribute name="selectWorkOrderId" type="String"/>
    <aura:attribute name="selectRecordName" type="String"/>
    <aura:attribute name="selectAssetName" type="String"/>
    <aura:attribute name="selectWorkOrderName" type="String"/>
    <aura:attribute name="Label" type="String"/>
    <aura:attribute name="searchRecords" type="List"/>
    <aura:attribute name="searchAssetRecords" type="List"/>
    <aura:attribute name="searchWorkOrderRecords" type="List"/>
    <aura:attribute name="required" type="Boolean" default="false"/>
    <aura:attribute name="iconName" type="String" default="action:new_account"/>
    <aura:attribute name="LoadingText" type="Boolean" default="false"/>
    <aura:attribute name="draftPRList" type="List"/>
    <aura:attribute name="showNoItem" type="Boolean"/>
    <aura:attribute name="checkAllCheckBox" type="Boolean" default="false"/>
    <aura:attribute Name="noItemQty" type="Integer"  access="public" /> 
    <aura:attribute name="unitList" type="List"/>
    <aura:attribute name="selectedDestinationUnit" type="String"/>
    
    <!-- data table variables -->
    <aura:attribute type="Purchase_Request__c[]" name="prList"/>
    <aura:attribute name="prcolumns" type="List"/>
    <aura:attribute name="selectedPRs" type="List"/>
    
    <!-- handlers-->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler event="force:refreshView" action="{!c.doInit}" />
    
    <lightning:overlayLibrary aura:id="overlayLib"/>
    <div class="slds-box slds-theme_default">
        <!--<p>
    Select a Store Item from below:
        </p><br/>
    <div style="width:40%">    
    <c:CustomLookupComponent objectName="Store_Item__c"
                          field_API_text="Name,Stock_Available_formula__c"
                          field_API_val="Id"
                          limit="5"
                          field_API_search="Name"
                          lookupIcon="standard:opportunity" 
                          selItem="{!v.selItem}" 
                          placeholder="Enter space after text to search Store Items"
                          /> 
    </div>-->
        <lightning:layout verticalAlign="end">
            <lightning:layoutItem class="left-align" size="5">
                <p><b>Select an Item from below : </b></p>
                <div class="custom-box">
                    <!--c:CustomLookupAura objectName="Store_Item__c"
                                    selectRecordId="{!v.selectRecordId1}"
                                    selectRecordName="{!v.selectRecordName1}"
                                    fieldName="Name"
                        /--> 
                    <div>
                        <div class="slds-form-element">
                            
                            <div class="slds-form-element__control">
                                <div class="slds-combobox_container">
                                    
                                    <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aura:id="resultBox" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon slds-input-has-icon_left-right" role="none">
                                            
                                            <aura:if isTrue="{!!empty(v.selectRecordId)}">
                                                <span class="slds-icon_container slds-icon-utility-search slds-input__icon iconheight">
                                                    <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="!v.iconName}" size="x-small" alternativeText="icon" />
                                                </span> 
                                            </aura:if>
                                            <lightning:input required="{!v.required}" aura:id="userinput" label="{!v.Label}" name="searchText" onchange="{!c.searchField}" value="{!v.selectRecordName}" class="leftspace"/> 
                                            <aura:if isTrue="{!empty(v.selectRecordId)}">
                                                <span class="slds-icon_container slds-icon-utility-search slds-input__icon slds-input__icon_right iconheight">
                                                    <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="utility:search" size="x-small" alternativeText="icon" />
                                                </span> 
                                                <aura:set attribute="else">
                                                    <button class="slds-input__icon slds-input__icon_right slds-button slds-button_icon iconheight" onclick="{!c.resetDataNow}">
                                                        <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default slds-p-top_xx-small" iconName="utility:clear" size="x-small" alternativeText="icon" />
                                                        <span class="slds-assistive-text">Clear</span></button>
                                                </aura:set>
                                            </aura:if>
                                        </div>
                                        
                                        <!-- Second part display result -->
                                        <div id="listbox-id-1" class="slds-dropdown slds-dropdown_length-with-icon-7 slds-dropdown_fluid" role="listbox">
                                            <ul class="slds-listbox slds-listbox_vertical" role="presentation">
                                                <aura:iteration items="{!v.searchRecords}" var="serecord" indexVar="hdtv">
                                                    <li role="presentation" class="slds-listbox__item">
                                                        
                                                        <div id="{!serecord.Id}" data-name="{!serecord.Name}"  onclick="{!c.setSelectedRecord}" class="slds-media slds-listbox__option slds-listbox__option_entity slds-listbox__option_has-meta" role="option">
                                                            <span class="slds-media__figure">
                                                                <span class="slds-icon_container slds-icon-standard-account">
                                                                    <lightning:icon iconName="{!v.iconName}" class="slds-icon slds-icon slds-icon_small slds-icon-text-default" size="x-small"/>
                                                                </span>
                                                            </span>
                                                            <span class="slds-media__body">
                                                                <span class="slds-listbox__option-text slds-listbox__option-text_entity">{!serecord.Name}</span>
                                                                <span class="slds-listbox__option-meta slds-listbox__option-meta_entity">{!serecord.Store_Item_Code__c} </span>
                                                            </span>
                                                        </div>
                                                    </li>
                                                </aura:iteration>
                                                <ul class="slds-listbox slds-listbox_vertical" role="presentation">
                                                    <li role="presentation" class="slds-listbox__item">
                                                        <div onclick="{!c.setNoItem}" id="newItem" class="slds-media slds-listbox__option slds-listbox__option_entity slds-listbox__option_has-meta" role="option">
                                                            <span class="slds-media__figure">
                                                                <span class="slds-icon_container slds-icon-standard-account">
                                                                    <!--lightning:icon iconName="{!v.iconName}" class="slds-icon slds-icon slds-icon_small slds-icon-text-default" size="x-small"/-->
                                                                </span>
                                                            </span>
                                                            <span class="slds-media__body">
                                                                <span class="slds-listbox__option-text slds-listbox__option-text_entity">Item not in list. Click to create a PR for this new Item</span>
                                                            </span>
                                                        </div>
                                                    </li>
                                                </ul>
                                                <aura:if isTrue="{!and(v.searchRecords.length == 0 , !v.LoadingText)}">
                                                    
                                                </aura:if>
                                                <aura:if isTrue="{!v.LoadingText}">
                                                    Loading...
                                                </aura:if>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    
                </div>
            </lightning:layoutItem>
        </lightning:layout>
        
        
        <aura:if isTrue="{!v.showSwitch}">
            <br/>
            <div class="slds-grid slds-wrap">  
                <!--[VP 18/11/21: Display if non-invetory item]-->
                <aura:if isTrue="{!v.isNonIventoryItem}">
                    <div class="slds-col slds-size_8-of-12">
                        <span><b>Selected item is non-inventory in Roma Base Store. The Purchase Request that will be created needs to be approved by Purchasing Officer as well.</b></span>
                    </div>
                </aura:if>
                <aura:if isTrue="{!!v.isNonIventoryItem}">
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                </aura:if>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <br/>
                               
                <aura:if isTrue="{!not(empty(v.unitList))}">
                    <div class="slds-col slds-size_1-of-12">
                        <span><b>Destination Store : </b></span>
                    </div>
                    <div class="slds-col slds-size_1-of-12" style="margin-top: -1%;margin-left: 2%;">
                        <span>
                            <lightning:select name="select" aura:id="selectedDestinationUnit" onchange="{!c.onDestinationChange}">
                                <option text="--Select--" value="x"></option>
                                <aura:iteration items="{!v.unitList}" var="eachUnit">
                                    <option text="{!eachUnit.Name}" value="{!eachUnit.Id}"></option>
                                </aura:iteration>
                            </lightning:select>
                        </span>
                    </div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                </aura:if>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                
                <div class="slds-col slds-size_12-of-12">
                    <span>&nbsp;</span>
                </div>
                
                <!--[VP 18/11/21: Hidden if non-invetory item]-->
                <aura:if isTrue="{!!v.isNonIventoryItem}">
                    <div class="slds-col slds-size_1-of-12">
                        <span><b>Source Store : </b></span>
                    </div>
                    <div class="slds-col slds-size_1-of-12" style="margin-left: 2%;">
                        <span>{!v.unitRecords.Store_Unit__r.Name}</span>
                    </div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    
                    <div class="slds-col slds-size_12-of-12">
                        <span>&nbsp;</span>
                    </div>
                    
                    <div class="slds-col slds-size_1-of-12">
                        <span><b>Available Stocks : </b></span>
                    </div>
                    <div class="slds-col slds-size_1-of-12" style="margin-left: 2%;">
                        <span>{!v.unitRecords.Stock_Available_formula__c}</span>
                    </div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                    <div class="slds-col slds-size_2-of-12"><span></span></div>
                </aura:if>

                <div class="slds-col slds-size_12-of-12">
                    <span>&nbsp;</span>
                </div>
                <div class="slds-col slds-size_1-of-6">
                    <span><b>Staff Name : </b></span>
                </div>
                <div class="slds-col slds-size_1-of-6" >
                    <span><lightning:input type="text" name="input0"  value="{!v.staffName}" style="margin-top: -8%;margin-left: -38%;margin-right: 80%;"></lightning:input></span>
                </div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                
                <div class="slds-col slds-size_12-of-12">
                    <span>&nbsp;</span>
                </div>
                
                <div class="slds-col slds-size_1-of-6">
                    <span><b>Quantity Requested : </b></span>
                </div>
                <div class="slds-col slds-size_1-of-6" >
                    <span><lightning:input type="number" name="input1" value="{!v.qty}" style="margin-top: -8%;margin-left: -38%;margin-right: 80%;"></lightning:input></span>
                </div>
                <div class="slds-col slds-size_1-of-6" style="margin-top: -0.5%;margin-left: -14%; !important;">
                    <span style="slds-p-bottom_medium ">
                        <aura:if isTrue="{!v.isCreatePR}">
                            <lightning:button class="slds-button slds-button_outline-brand slds-align_absolute-center "
                                              label="Create Purchase Request" 
                                              onclick="{!c.startPRCreate}"
                                              />
                        </aura:if>
                        <aura:if isTrue="{!!v.isCreatePR}">
                            <div style="margin-left:-30%; !important">
                                <lightning:button class="slds-button slds-button_outline-brand slds-align_absolute-center "
                                                  label="Create Purchase Request" 
                                                  onclick="{!c.startPRCreate}"
                                                  
                                                  
                                                  />
                            </div>
                            
                        </aura:if>
                    </span>
                </div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_1-of-12"><span></span></div>
                
                <div class="slds-col slds-size_12-of-12">
                    <span>&nbsp;</span>
                </div>
                
                <!-- MEHUL -->
				<div class="slds-col slds-size_1-of-12" style="margin-top: 1%;">
                    <span><b>Asset : </b></span>
                </div>
                <div class="slds-col slds-size_2-of-12" >
                    <span>
                        
                        <div class="custom-box" >
                            <!--c:CustomLookupAura objectName="Store_Item__c"
                                    selectRecordId="{!v.selectRecordId1}"
                                    selectRecordName="{!v.selectRecordName1}"
                                    fieldName="Name"
                        /-->
                            <div>
                                <div class="slds-form-element">
                                    
                                    <div class="slds-form-element__control">
                                        <div class="slds-combobox_container">
                                            
                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aura:id="resultBoxAsset" aria-expanded="false" aria-haspopup="listbox" role="combobox" style="margin-left:12%;">
                                                <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon slds-input-has-icon_left-right" role="none" >
                                                    
                                                    <aura:if isTrue="{!!empty(v.selectAssetId)}">
                                                        <span class="slds-icon_container slds-icon-utility-search slds-input__icon iconheight" >
                                                            <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="!v.iconName}" size="x-small" alternativeText="icon" />
                                                        </span>
                                                    </aura:if>
                                                    <lightning:input required="{!v.required}" aura:id="userinputAsset" label="{!v.Label}" name="searchText" onchange="{!c.searchAssetField}" value="{!v.selectAssetName}" class="leftspace"/>
                                                    <aura:if isTrue="{!empty(v.selectAssetId)}">
                                                        <span class="slds-icon_container slds-icon-utility-search slds-input__icon slds-input__icon_right iconheight">
                                                            <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="utility:search" size="x-small" alternativeText="icon" />
                                                        </span>
                                                        <aura:set attribute="else">
                                                            <button class="slds-input__icon slds-input__icon_right slds-button slds-button_icon iconheight" onclick="{!c.assetResetDataNow}">
                                                                <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default slds-p-top_xx-small" iconName="utility:clear" size="x-small" alternativeText="icon" />
                                                                <span class="slds-assistive-text">Clear</span></button>
                                                        </aura:set>
                                                    </aura:if>
                                                </div>
                                                
                                                <!-- Second part display result -->
                                                <div id="listbox-id-1" class="slds-dropdown slds-dropdown_length-with-icon-7 slds-dropdown_fluid" role="listbox" style="margin-left: 7%;width:91%;">
                                                    <ul class="slds-listbox slds-listbox_vertical" role="presentation">
                                                        <aura:iteration items="{!v.searchAssetRecords}" var="serecord" indexVar="hdtv">
                                                            <li role="presentation" class="slds-listbox__item">
                                                                
                                                                <div id="{!serecord.Id}" data-name="{!serecord.Name}"  onclick="{!c.setSelectedAssetRecord}" class="slds-media slds-listbox__option slds-listbox__option_entity slds-listbox__option_has-meta" role="option">
                                                                    <span class="slds-media__figure">
                                                                        <span class="slds-icon_container slds-icon-standard-account">
                                                                            <lightning:icon iconName="{!v.iconName}" class="slds-icon slds-icon slds-icon_small slds-icon-text-default" size="x-small"/>
                                                                        </span>
                                                                    </span>
                                                                    <span class="slds-media__body">
                                                                        <span class="slds-listbox__option-text slds-listbox__option-text_entity">{!serecord.Name}</span>
                                                                    </span>
                                                                </div>
                                                            </li>
                                                        </aura:iteration>
                                                        <!-- TENTATIVE -->
                                                        <aura:if isTrue="{!v.searchAssetRecords.length == 0 }">
                                                        
                                                        <ul class="slds-listbox slds-listbox_vertical" role="presentation">
                                                            <li role="presentation" class="slds-listbox__item">
                                                                <div id="newItem" class="slds-media slds-listbox__option slds-listbox__option_entity slds-listbox__option_has-meta" role="option">
                                                                    <span class="slds-media__figure">
                                                                        <span class="slds-icon_container slds-icon-standard-account">
                                                                        </span>
                                                                    </span>
                                                                    <span class="slds-media__body">
                                                                        <span class="slds-listbox__option-text slds-listbox__option-text_entity">No Asset Found</span>
                                                                    </span>
                                                                </div>
                                                            </li>
                                                        </ul>
                                                            </aura:if>
                                                        <!-- TENTATIVE -->
                                                        <aura:if isTrue="{!v.LoadingText}">
                                                            Loading...
                                                        </aura:if>
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            
                        </div>
                        
                    </span>

                </div>
                <!--<div class="slds-col slds-size_2-of-12"><span></span></div>-->
                <div class="slds-col slds-size_3-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                <div class="slds-col slds-size_2-of-12"><span></span></div>
                
                <div class="slds-col slds-size_12-of-12">
                    <span>&nbsp;</span>
                </div>
                
                
                <div class="slds-col slds-size_1-of-12">
                    <span><b>Work Order : </b></span>
                </div>
                <div class="slds-col slds-size_2-of-12" style=" margin-top: -1%;margin-left: -2%;">
                    <span>
                        
                    	<div class="custom-box">
                    <!--c:CustomLookupAura objectName="Store_Item__c"
                                    selectRecordId="{!v.selectRecordId1}"
                                    selectRecordName="{!v.selectRecordName1}"
                                    fieldName="Name"
                        /--> 
                    <div>
                        <div class="slds-form-element">
                            
                            <div class="slds-form-element__control">
                                <div class="slds-combobox_container">
                                    
                                    <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aura:id="resultBoxWorkOrder" aria-expanded="false" aria-haspopup="listbox" role="combobox" >
                                        <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon slds-input-has-icon_left-right" role="none" style="margin-left: 24%;margin-right: -12%;" >
                                            
                                            <aura:if isTrue="{!!empty(v.selectWorkOrderId)}">
                                                <span class="slds-icon_container slds-icon-utility-search slds-input__icon iconheight">
                                                    <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="!v.iconName}" size="x-small" alternativeText="icon" />
                                                </span> 
                                            </aura:if>
                                            <lightning:input required="{!v.required}" aura:id="userinputWorkOrder" label="{!v.Label}" name="searchText" onchange="{!c.searchWorkOrder}" value="{!v.selectWorkOrderName}" class="leftspace"/> 
                                            <aura:if isTrue="{!empty(v.selectWorkOrderId)}">
                                                <span class="slds-icon_container slds-icon-utility-search slds-input__icon slds-input__icon_right iconheight">
                                                    <lightning:icon class="slds-icon slds-icon slds-icon_small slds-icon-text-default" iconName="utility:search" size="x-small" alternativeText="icon" />
                                                </span> 
